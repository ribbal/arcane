{
  "name": "arcane-repo",
  "private": true,
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f",
  "engines": {
    "node": ">=26"
  },
  "workspaces": [
    "frontend",
    "tests",
    "email-templates"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky"
  },
  "lint-staged": {
    "frontend/**/*": [
      "sh -c 'just format frontend --check'"
    ],
    "{tests,email-templates}/**/*.{ts,tsx,js,jsx,mts,cts}": [
      "sh -c 'just format js --check'"
    ],
    "{backend,cli,types}/**/*": [
      "sh -c 'just format go --check'"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7"
  }
}
